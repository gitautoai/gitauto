{
  "name": "foxcom-forms",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@apollo/client": "^3.3.13",
    "@apollo/link-error": "^2.0.0-beta.3",
    "@date-io/date-fns": "1.x",
    "@foxden/version-controller-client": "^1.3.6",
    "@material-ui/core": "^4.12.1",
    "@material-ui/icons": "^4.11.3",
    "@material-ui/lab": "^4.0.0-alpha.61",
    "@material-ui/pickers": "^3.3.10",
    "@sentry/react": "^6.2.3",
    "@testing-library/jest-dom": "^5.11.10",
    "@testing-library/react": "^11.2.5",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^26.0.22",
    "@types/node": "22.15.32",
    "@types/react": "^17.0.3",
    "@types/react-dom": "^17.0.3",
    "@types/react-gtm-module": "^2.0.1",
    "@types/react-html-parser": "^2.0.1",
    "@types/react-places-autocomplete": "^7.2.6",
    "@types/react-router-dom": "^5.1.7",
    "autoprefixer": "^9",
    "date-fns": "^2.20.2",
    "date-fns-tz": "^1.1.3",
    "env-cmd": "^10.1.0",
    "graphql": "^15.5.0",
    "graphql-request": "5.1.0",
    "graphql-tag": "^2.11.0",
    "lodash": "^4.17.23",
    "postcss-cli": "^8.3.1",
    "public-ip": "^4.0.4",
    "react": "^17.0.2",
    "react-cookie": "^4.0.3",
    "react-dom": "^17.0.2",
    "react-gtm-module": "^2.0.11",
    "react-html-parser": "^2.0.2",
    "react-number-format": "^4.5.1",
    "react-phone-input-2": "^2.13.8",
    "react-places-autocomplete": "^7.3.0",
    "react-router-dom": "^5.2.0",
    "react-scripts": "4.0.3",
    "survey-core": "^1.9.24",
    "survey-react-ui": "1.9.24",
    "typescript": "^5.8.3",
    "zod": "^3.22.3"
  },
  "scripts": {
    "start": "yarn build:css && cross-env NODE_OPTIONS=--openssl-legacy-provider craco start",
    "build": "yarn build:css && cross-env NODE_OPTIONS=--openssl-legacy-provider craco build",
    "build:development": "env-cmd -f .env.development yarn build",
    "build:green-dev": "env-cmd -f .env.green-dev yarn build",
    "build:green-stage": "env-cmd -f .env.green-stage yarn build",
    "build:blue-dev": "env-cmd -f .env.blue-dev yarn build",
    "build:magenta-dev": "env-cmd -f .env.magenta-dev yarn build",
    "build:stage": "env-cmd -f .env.stage yarn build",
    "build:production": "env-cmd -f .env.production yarn build",
    "test": "craco test --coverage=true",
    "eject": "react-scripts eject",
    "lint": "eslint --cache --ext .js,.ts,.tsx ./src",
    "lint:fix": "eslint --cache --fix --ext .js,.ts,.tsx ./src",
    "build:css": "postcss src/styles/tailwind.css -o src/styles/main.css",
    "storybook": "start-storybook -p 6006 -s public",
    "build-storybook": "build-storybook -s public",
    "build:graphql": "cross-env DOTENV_CONFIG_PATH=./.env.local graphql-codegen -r dotenv/config --config codegen.yml",
    "build:graphql:payment": "graphql-codegen --config codegen-payment.yml",
    "build:graphql:rating-quoting": "cross-env DOTENV_CONFIG_PATH=./.env.local graphql-codegen -r dotenv/config --config codegen-rating-quoting.yml",
    "e2eTest-open": "env-cmd -f .env.development.local cypress open",
    "cypress-test": "env-cmd -f .env.development.local cypress run",
    "cypress-test:development": "env-cmd -f .env.development cypress run --record",
    "cypress-test:green-dev": "env-cmd -f .env.green-dev cypress run --record",
    "cypress-test:green-stage": "env-cmd -f .env.green-stage cypress run --record",
    "cypress-test:blue-dev": "env-cmd -f .env.blue-dev cypress run --record",
    "cypress-test:magenta-dev": "env-cmd -f .env.magenta-dev cypress run --record",
    "cypress-test:stage": "env-cmd -f .env.stage cypress run --record",
    "cypress-test:prod": "env-cmd -f .env.production cypress run --record"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.13.10",
    "@craco/craco": "^6.4.3",
    "@graphql-codegen/cli": "^1.21.3",
    "@graphql-codegen/typescript": "^1.21.1",
    "@graphql-codegen/typescript-graphql-request": "^3.1.0",
    "@graphql-codegen/typescript-operations": "^1.17.15",
    "@graphql-codegen/typescript-react-apollo": "^2.2.3",
    "@storybook/addon-actions": "^6.1.21",
    "@storybook/addon-essentials": "^6.1.21",
    "@storybook/addon-knobs": "^6.1.21",
    "@storybook/addon-links": "^6.1.21",
    "@storybook/node-logger": "^6.1.21",
    "@storybook/preset-create-react-app": "^3.1.7",
    "@storybook/react": "^6.1.21",
    "@types/dotenv-flow": "^3.1.0",
    "@types/lodash": "^4.14.168",
    "@typescript-eslint/eslint-plugin": "^4.19.0",
    "@typescript-eslint/parser": "^4.19.0",
    "cross-env": "^7.0.3",
    "cypress": "5.5.0",
    "dotenv-flow": "^3.2.0",
    "eslint-config-prettier": "^8.1.0",
    "eslint-plugin-prettier": "^3.3.1",
    "eslint-plugin-react": "^7.23.1",
    "eslint-plugin-simple-import-sort": "^7.0.0",
    "jest-launchdarkly-mock": "^2.1.0",
    "launchdarkly-react-client-sdk": "^3.0.10",
    "lint-staged": "^10.5.4",
    "postcss": "^8.4.31",
    "prettier": "^2.0.5",
    "react-is": "^17.0.2",
    "segfault-handler": "^1.3.0",
    "simple-git-hooks": ">=2.0.3",
    "tailwindcss": "npm:@tailwindcss/postcss7-compat"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "yarn lint:fix",
      "eslint --cache --fix"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "packageManager": "yarn@1.22.17",
  "resolutions": {
    "@sentry/browser": "7.119.1"
  }
}
