{
  "name": "foxcom-payment-backend",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build:graphql:document": "cross-env DOTENV_CONFIG_PATH=./.env.localhost graphql-codegen -r dotenv/config -c ./codegen-document.yml",
    "build:graphql:payment": "graphql-codegen -c ./codegen-payment.yml",
    "build:graphql:payment-mongodb": "graphql-codegen -c ./codegen-payment-mongodb.yml",
    "deploy:development": "sls deploy --stage dev",
    "deploy:green-dev": "sls deploy --stage green-dev",
    "deploy:green-stage": "sls deploy --stage green-stage",
    "deploy:blue-dev": "sls deploy --stage blue-dev",
    "deploy:production": "sls deploy --stage prod",
    "deploy:staging": "sls deploy --stage stage",
    "lint": "eslint --cache --ext .js,.ts,.tsx ./src",
    "lint:fix": "eslint --cache --fix --ext .js,.ts,.tsx ./src",
    "migrate-mongo:development": "cross-env stage=dev migrate-mongo",
    "migrate-mongo:green-dev": "cross-env stage=green-dev migrate-mongo",
    "migrate-mongo:green-stage": "cross-env stage=green-stage migrate-mongo",
    "migrate-mongo:blue-dev": "cross-env stage=blue-dev migrate-mongo",
    "migrate-mongo:local": "cross-env stage=local migrate-mongo",
    "migrate-mongo:production": "cross-env stage=prod migrate-mongo",
    "migrate-mongo:staging": "cross-env stage=stage migrate-mongo",
    "start": "cross-env NODE_ENV=localhost NODE_OPTIONS='--max-old-space-size=6144' APP_VERSION=2022-06-30 sls offline start --stage local",
    "debug": "export SLS_DEBUG=* && NODE_ENV=localhost APP_VERSION=2022-06-30 node --inspect ./node_modules/serverless/bin/serverless offline start --stage local --aws-profile sandbox",
    "start:stripe-canada": "stripe listen --forward-to http://localhost:4000/local/2022-06-30/stripe/webhook --project-name canada",
    "start:stripe-us": "stripe listen --forward-to http://localhost:4000/local/2022-06-30/stripe/webhook-us --project-name us",
    "stripe-login:canada": "stripe login --project-name canada",
    "stripe-login:us": "stripe login --project-name us",
    "test": "cross-env MONGOMS_VERSION=v7.0-latest jest --coverage --coverageReporters=\"lcov\""
  },
  "devDependencies": {
    "@graphql-codegen/cli": "1.21.3",
