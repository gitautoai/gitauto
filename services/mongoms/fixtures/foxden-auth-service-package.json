{
  "name": "foxden-auth",
  "version": "1.0.0",
  "description": "Auth service for the Foxden platform",
  "main": "src/index.ts",
  "author": "Foxquilt",
  "license": "unlicense",
  "private": true,
  "scripts": {
    "docker:build": "docker build -t foxden/auth-service --build-arg NPM_TOKEN=$NPM_TOKEN .",
    "docker:run": "docker run -it -p 3102:3102 foxden/auth-service",
    "compile": "tsc",
    "format": "prettier --write --ignore-unknown .",
    "lint": "eslint --ext .js,.ts src/ test/",
    "lint:fix": "eslint --cache --fix --ext .js,.ts,.ts src/ test/",
    "prepare": "husky install",
    "start": "nodemon src/index.ts",
    "test": "cross-env MONGOMS_VERSION=v7.0-latest jest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.980.0",
    "@aws-sdk/client-secrets-manager": "3.974.0",
    "@aws-sdk/client-ssm": "3.974.0",
    "@aws-sdk/s3-request-presigner": "3.980.0",
    "@foxden/config": "^0.2.0",
    "@foxden/saml-passport": "^4.0.2",
    "@foxden/shared-lib": "^2.16.18",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.17.5",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "22.15.32",
    "@types/passport": "^1.0.11",
    "@types/passport-auth0": "^1.0.5",
    "@types/passport-openidconnect": "^0.1.3",
    "dotenv-defaults": "^5.0.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^5.8.0",
    "passport": "^0.6.0",
    "passport-auth0": "^1.4.3",
    "passport-openidconnect": "^0.1.2",
    "path-to-regexp": "^0.1.13",
    "pug": "^3.0.3",
    "saml2js": "^0.1.2",
    "ts-node": "^10.9.1",
    "typescript": "^4.8.4",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^7.6.0",
    "@types/jest": "^29.1.1",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^5.39.0",
    "@typescript-eslint/parser": "^5.39.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.24.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-simple-import-sort": "^8.0.0",
    "express": "4.22.0",
    "husky": "^8.0.1",
    "jest": "^29.1.2",
    "jest-junit": "^14.0.1",
    "lint-staged": "^13.0.3",
    "mongodb-memory-server": "^9.2.0",
    "moq.ts": "^9.0.2",
    "node-mocks-http": "^1.11.0",
    "nodemon": "^2.0.20",
    "prettier": "^2.7.1",
    "supertest": "^6.3.1",
    "ts-jest": "^29.0.3"
  },
  "lint-staged": {
    "**/*.{t,j}s": "eslint --fix",
    "**/*.{tf,tfvars}": "terraform fmt",
    "**/*": "prettier --write --ignore-unknown"
  },
  "resolutions": {
    "xml2js": "0.5.0",
    "send": "0.19.0",
    "xml-crypto": "3.2.1",
    "jws": "3.2.3",
    "nodemailer": "7.0.11",
    "@smithy/config-resolver": "4.4.0",
    "fast-xml-parser": "5.3.4",
    "axios": "1.13.5",
    "qs": "6.14.2",
    "body-parser": "1.20.4",
    "@aws-sdk/client-sesv2": "3.980.0",
    "@aws-sdk/xml-builder": "3.972.5"
  },
  "packageManager": "yarn@1.22.17"
}
