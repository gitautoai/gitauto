{
  "name": "foxden-billing",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build:graphql:underwriting": "graphql-codegen -c ./codegen-underwriting.yml",
    "build:graphql:rating-quoting": "VERSION_NUMBER=2022-06-30 graphql-codegen -c ./codegen-rating-quoting.yml",
    "build:graphql:billing-mongodb": "graphql-codegen -c ./codegen-billing-mongodb.yml",
    "deploy:development": "sls deploy --stage dev",
    "deploy:green-dev": "sls deploy --stage green-dev",
    "deploy:green-stage": "sls deploy --stage green-stage",
    "deploy:production": "sls deploy --stage prod",
    "deploy:staging": "sls deploy --stage stage",
    "lint": "eslint --ext .js,.ts,.tsx ./src",
    "lint:fix": "eslint --fix --ext .js,.ts,.tsx ./src",
    "migrate-mongo:development": "cross-env stage=dev migrate-mongo",
    "migrate-mongo:green-dev": "cross-env stage=green-dev migrate-mongo",
    "migrate-mongo:green-stage": "cross-env stage=green-stage migrate-mongo",
    "migrate-mongo:local": "cross-env stage=local migrate-mongo",
    "migrate-mongo:production": "cross-env stage=prod migrate-mongo",
    "migrate-mongo:staging": "cross-env stage=stage migrate-mongo",
    "start": "cross-env NODE_ENV=localhost serverless invoke local --function billing --stage local",
    "start:renewal": "cross-env NODE_ENV=localhost serverless invoke local --function renewal-billing --stage local",
    "test": "jest"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@faker-js/faker": "^7.6.0",
    "@graphql-codegen/cli": "^1.21.6",
    "@graphql-codegen/typescript": "^1.22.4",
    "@graphql-codegen/typescript-graphql-request": "^3.2.4",
    "@graphql-codegen/typescript-operations": "^1.18.3",
    "@graphql-codegen/typescript-resolvers": "^1.19.5",
    "@types/jest": "28",
    "@types/mongodb": "^3.5.26",
    "@types/node": "22",
    "@types/uuid": "^8.3.0",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "copy-webpack-plugin": "^8.1.0",
    "cross-env": "^7.0.2",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-import": "^2.22.0",
    "eslint-plugin-prettier": "^3.1.4",
    "eslint-plugin-simple-import-sort": "^7.0.0",
    "globals": "^17.4.0",
    "jest": "^30.0.0",
    "jest-transform-stub": "^2.0.0",
    "lint-staged": ">=10",
    "nodemailer-mock": "^2.0.1",
    "prettier": "^2.0.5",
    "raw-loader": "^4.0.2",
    "serverless": "^4.18.0",
    "serverless-dotenv-plugin": "^6.0.0",
    "serverless-offline": "^14.4.0",
    "serverless-webpack": "^5.15.1",
    "ts-jest": "^29.3.4",
    "ts-loader": "^8.0.1",
    "typescript": "^4.1.3",
    "webpack": "^5.94.0",
    "webpack-cli": "^3.3.12",
    "webpack-node-externals": "^2.5.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.850.0",
    "@aws-sdk/client-secrets-manager": "^3.848.0",
    "@aws-sdk/client-ssm": "^3.848.0",
    "@aws-sdk/s3-request-presigner": "^3.848.0",
    "@babel/helper-globals": "^7.28.0",
    "@foxden/config": "^0.2.0",
    "@foxden/shared-lib": "^2.16.9",
    "@foxden/version-controller-client": "^1.3.6",
    "@graphql-tools/schema": "^7.1.5",
    "@sentry/node": "^6.8.0",
    "@types/lodash": "^4.17.18",
    "@types/nodemailer": "^7.0.2",
    "@types/qs": "^6.9.18",
    "bignumber.js": "^9.0.2",
    "date-fns": "^2.16.1",
    "date-fns-tz": "^1.1.3",
    "express": "^4.20.0",
    "graphql": "^15.5.1",
    "graphql-request": "^3.6.1",
    "graphql-scalars": "^1.10.0",
    "graphql-tag": "^2.12.5",
    "handlebars": "^4.7.9",
    "jest-raw-loader": "^1.0.1",
    "migrate-mongo": "^8.2.2",
    "moment": "^2.29.4",
    "mongodb": "^5.8.0",
    "mongodb-memory-server": "^10.0.0",
    "nodemailer": "8.0.4",
    "path": "^0.12.7",
    "qs": "^6.14.2",
    "serverless-prune-plugin": "^2.0.2",
    "simple-git-hooks": "^2.5.1",
    "stripe": "^8.161.0",
    "uuid": "^8.3.0",
    "winston": "^3.3.3",
    "winston-transport-sentry-node": "^2.3.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": "yarn eslint --cache --fix"
  },
  "packageManager": "yarn@1.22.17",
  "resolutions": {
    "formidable": "3.5.0",
    "axios": "1.8.3",
    "braces": "3.0.3",
    "cookie": "0.7.0",
    "xml2js": "0.5.0",
    "@launchdarkly/js-sdk-common": "2.2.0",
    "@launchdarkly/js-server-sdk-common": "2.2.0",
    "@launchdarkly/node-server-sdk": "9.2.0",
    "@babel/traverse": "7.23.2",
    "form-data": "3.0.4",
    "on-headers": "1.1.0",
    "brace-expansion": "2.0.2",
    "nodemailer": "8.0.4",
    "@smithy/config-resolver": "4.4.6",
    "lodash": "4.17.23",
    "fast-xml-parser": "5.3.6"
  }
